NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Sent as the User-Agent to OpenStreetMap Nominatim for location search.
# Their usage policy requires identifying the app and a real contact (URL or email).
# NOMINATIM_USER_AGENT=DispatchDesk/1.0 (you@example.com)

# Optional production error-monitoring webhook. Server errors are always logged
# as structured JSON; when set, sanitized error events are also posted here.
# ERROR_MONITORING_WEBHOOK_URL=https://monitoring.example.com/events
# ERROR_MONITORING_WEBHOOK_TOKEN=replace-with-a-secret-token
# APP_RELEASE=production-release-id
